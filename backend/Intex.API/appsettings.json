{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FrontendUrl": "http://localhost:3000",
  "ConnectionStrings": {
    "AppConnection": "Data Source=Intex.sqlite",
    "IdentityConnection": "Data Source=Identity.sqlite"
  },
  "MlInferenceService": {
    "BaseUrl": "http://127.0.0.1:8001",
    "TimeoutSeconds": 60,
    "ApiKey": "",
    "ApiKeyHeaderName": "X-ML-Service-Key"
  },
  "Intex": {
    "UseSqliteInDevelopment": true,
    "SeedCsvAfterMigrate": false,
    "SeedCsvAtStartup": false,
    "SeedCsvReplaceExisting": false,
    "AllowProductionCsvSeed": false
  }
}
